APP_NAME=SmartWealth AI Core
APP_ENV=local
LOG_LEVEL=INFO
INTERNAL_WORKFLOW_EVENT_TOKEN=

# Database: either a single URL or host/user/password/name (used if DATABASE_URL is empty)
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=smartwealth
# PostgreSQL search_path (optional), e.g. myapp or myapp,public
DB_SCHEMA=

# Workflow HTTP API persistence: bảng workflow_state + workflow_audit_event (xem README và PostgresStateRepository / PostgresAuditLogger).

# LLM: deepseek (default) or azure_openai
# LLM_PROVIDER=deepseek

# DeepSeek (OpenAI-compatible API) — scripts/try_deepseek_prompt.py
# When ``ai_llm_profile.is_active`` has keys set via admin UI, AI-engine merges them over these env defaults.
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# Azure OpenAI — used when LLM_PROVIDER=azure_openai
# AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=your-deployment-name
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ASSESSMENT_LLM_ENABLED=false
